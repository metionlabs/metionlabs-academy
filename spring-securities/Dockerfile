# syntax=docker/dockerfile:1
#
# 위 한 줄은 주석이 아니라 "지시어(directive)" 다.
# 도커에게 최신 Dockerfile 문법 파서를 쓰라고 알려준다.
# 이게 있어야 아래에서 쓰는 최신 문법들이 안전하게 동작한다. 항상 첫 줄에 둔다.
#
# ############################################################################
# 이 Dockerfile 은 앞 예제(spring-boot-dockers)와 사실상 동일하다.
# 도커 빌드 자체를 배우는 건 그쪽 예제의 주제이므로, 여기서는 그대로 재사용한다.
# 각 줄의 자세한 설명이 필요하면 spring-boot-dockers/Dockerfile 을 참고할 것.
#
# 이 예제의 새로운 부분은 Dockerfile 이 아니라 소스 코드(JWT 인증)와
# compose.yaml 의 JWT_SECRET 주입에 있다.
# ############################################################################

# ############################################################################
# 이 Dockerfile 이 하는 일 (전체 그림)
# ----------------------------------------------------------------------------
#   [1단계 builder]  JDK 이미지 안에서 gradle 로 빌드해서 jar 를 만든다  (무겁다, ~700MB)
#                        |
#                        |  결과물(jar 를 풀어놓은 것)만 넘김
#                        v
#   [2단계 runtime]  JRE 이미지에 그 결과물만 얹어서 최종 이미지를 만든다 (가볍다, ~530MB)
#
# 1단계 이미지는 최종 결과물에 포함되지 않고 버려진다.
# 이것이 multi-stage build 이고, 이걸 안 하면 최종 이미지에 gradle·컴파일러·소스코드가
# 전부 딸려 들어가서 이미지가 1GB 를 훌쩍 넘고 보안상으로도 나빠진다.
# ############################################################################


# ============================================================================
# 1단계: 빌드 (builder)
# ============================================================================
# FROM  = 어떤 이미지에서 출발할지.
# AS builder = 이 단계에 "builder" 라는 이름을 붙인다. 아래 2단계에서 이 이름으로 참조한다.
# eclipse-temurin:25-jdk = Eclipse Temurin 의 JDK 25 이미지.
#   JDK = 컴파일러 포함(빌드 가능) / JRE = 실행만 가능.
#   빌드를 해야 하니 여기서는 JDK 가 필요하다.
FROM eclipse-temurin:25-jdk AS builder

# WORKDIR = 이후 명령들이 실행될 작업 디렉토리. 없으면 자동으로 만들어준다.
# cd 와 비슷하지만, 이후 모든 RUN/COPY 에 계속 적용된다는 점이 다르다.
WORKDIR /workspace

# ----------------------------------------------------------------------------
# [중요] 왜 소스(src)를 지금 복사하지 않고 의존성 파일만 먼저 복사하는가?
# ----------------------------------------------------------------------------
# 도커는 각 명령(RUN, COPY ...)의 결과를 "레이어"로 저장해두고 재사용한다(캐시).
# 그런데 어떤 레이어의 입력이 바뀌면, 그 레이어부터 아래 전부가 캐시 무효화된다.
#
#  - 소스코드: 하루에도 수십 번 바뀜
#  - 의존성 목록(build.gradle.kts): 거의 안 바뀜
#
# 그래서 "잘 안 바뀌는 것 -> 자주 바뀌는 것" 순서로 복사해야 한다.
# 만약 COPY src src 를 맨 위로 올리면, 주석 한 글자만 고쳐도
# 그 아래 의존성 다운로드가 통째로 다시 실행된다 (매번 몇 분씩 낭비).
# ----------------------------------------------------------------------------

# gradle wrapper = 이 프로젝트가 쓸 gradle 버전을 프로젝트 안에 박아두는 장치.
# 덕분에 빌드 머신에 gradle 이 깔려 있지 않아도, 버전이 달라도 항상 같은 버전으로 빌드된다.
COPY gradlew ./
COPY gradle gradle

# 의존성이 정의된 빌드 스크립트들.
COPY settings.gradle.kts build.gradle.kts ./

# chmod +x = 실행 권한 부여. (윈도우에서 커밋하면 실행 권한이 날아가는 경우가 있어 방어적으로 넣는다)
# ./gradlew dependencies = 의존성만 미리 내려받아 캐시 레이어로 굳혀둔다.
#   > /dev/null 2>&1  : 출력이 너무 길어서 버린다. (stdout, stderr 둘 다)
#   || true           : 이 단계가 실패해도 빌드를 계속한다.
#                       여기서 실패해도 다음 bootJar 단계에서 어차피 다시 받으므로 치명적이지 않다.
RUN chmod +x gradlew && ./gradlew --no-daemon dependencies > /dev/null 2>&1 || true

# 이제서야 소스를 복사한다. 여기부터가 "자주 바뀌는 영역".
COPY src src

# bootJar = Spring Boot 실행 가능 jar 를 만드는 gradle 태스크.
# --no-daemon = gradle 데몬(백그라운드 상주 프로세스)을 띄우지 않는다.
#   컨테이너는 빌드 끝나면 사라지므로 데몬이 무의미하고, 메모리만 잡아먹는다.
RUN ./gradlew --no-daemon clean bootJar

# ----------------------------------------------------------------------------
# jar 를 "레이어" 단위로 분해하기
# ----------------------------------------------------------------------------
# Spring Boot jar 를 그냥 통째로 COPY 하면 하나의 큰 레이어(수십 MB)가 된다.
# 코드 한 줄만 고쳐도 그 수십 MB 레이어가 통째로 새로 만들어지고,
# 서버에 배포할 때도 매번 그만큼을 새로 전송해야 한다.
#
# extract --layers 를 쓰면 jar 안이 이렇게 나뉜다:
#   dependencies/          라이브러리들   (거의 안 바뀜, 제일 큼)
#   spring-boot-loader/    부트 로더      (거의 안 바뀜)
#   snapshot-dependencies/ 스냅샷 의존성  (가끔 바뀜)
#   application/           내가 짠 코드   (매번 바뀜, 제일 작음)
#
# 이렇게 나눠서 복사하면, 코드만 고쳤을 때 마지막 작은 레이어 하나만 새로 만들어진다.
#
# --launcher = 실행에 필요한 로더까지 같이 풀어준다 (jar 없이도 실행 가능한 형태).
# *-SNAPSHOT.jar = 와일드카드. plain.jar 같은 부산물을 피하려고 버전 패턴으로 집는다.
RUN java -Djarmode=tools -jar build/libs/*-SNAPSHOT.jar extract --layers --launcher --destination extracted


# ============================================================================
# 2단계: 런타임 (runtime)
# ============================================================================
# 여기서부터 완전히 새 이미지가 시작된다. 위 builder 의 파일은 명시적으로 가져오지 않으면 없다.
# JDK 가 아니라 JRE 를 쓴다:
#   - 실행에는 컴파일러가 필요 없다
#   - 이미지가 작아진다
#   - 컨테이너가 뚫렸을 때 공격자가 쓸 수 있는 도구가 줄어든다 (공격 표면 축소)
FROM eclipse-temurin:25-jre AS runtime

WORKDIR /app

# ----------------------------------------------------------------------------
# healthcheck 용 curl 설치
# ----------------------------------------------------------------------------
# temurin JRE 이미지에는 curl 도 wget 도 없다. (군더더기를 최대한 뺀 이미지라서)
# compose 의 healthcheck 가 HTTP 를 찔러야 하므로 curl 만 최소로 설치한다.
#
#   --no-install-recommends : 추천 패키지까지 줄줄이 딸려오는 것을 막는다 (용량 절약)
#   rm -rf /var/lib/apt/lists/* : apt 캐시 삭제.
#       이걸 같은 RUN 안에서 해야 의미가 있다. 다음 RUN 으로 분리하면
#       앞 레이어에 캐시가 이미 굳어버려서 이미지 크기가 안 줄어든다.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# ----------------------------------------------------------------------------
# root 로 실행하지 않기
# ----------------------------------------------------------------------------
# 컨테이너는 기본적으로 root 로 돈다. 앱에 취약점이 생겨 침입당했을 때
# root 면 컨테이너 안에서 뭐든 할 수 있고, 호스트로 탈출할 여지도 커진다.
# 전용 계정을 만들어 권한을 낮춘다. 실무 배포에서는 사실상 필수다.
#
#   --system              : 시스템 계정 (로그인용 아님)
#   --create-home         : 홈 디렉토리 생성 (일부 툴이 HOME 을 요구함)
#   --shell /usr/sbin/nologin : 셸 로그인 차단
RUN useradd --system --create-home --shell /usr/sbin/nologin spring

# 이 시점 이후의 명령과 컨테이너 실행이 spring 계정으로 이뤄진다.
# (apt 설치는 root 권한이 필요하므로 반드시 그 뒤에 와야 한다)
USER spring

# ----------------------------------------------------------------------------
# 1단계에서 만든 결과물을 레이어별로 가져오기
# ----------------------------------------------------------------------------
# --from=builder : 앞 단계 이미지에서 가져온다는 뜻.
# --chown        : 복사하면서 소유자를 spring 으로 바꾼다.
#                  (안 하면 root 소유 파일이 되어 spring 계정이 못 읽는 문제가 생길 수 있다)
#
# 순서가 중요하다: 안 바뀌는 것부터 복사해야 캐시가 최대한 살아남는다.
COPY --from=builder --chown=spring:spring /workspace/extracted/dependencies/ ./
COPY --from=builder --chown=spring:spring /workspace/extracted/spring-boot-loader/ ./
COPY --from=builder --chown=spring:spring /workspace/extracted/snapshot-dependencies/ ./
COPY --from=builder --chown=spring:spring /workspace/extracted/application/ ./

# EXPOSE = "이 컨테이너는 8080 을 쓴다" 는 문서화 겸 메타데이터.
# 주의: 이것만으로는 외부에서 접속 안 된다. 실제 연결은 docker run -p 또는 compose 의 ports 가 한다.
EXPOSE 8080

# ----------------------------------------------------------------------------
# [중요] 컨테이너 안의 JVM 메모리 설정
# ----------------------------------------------------------------------------
# JVM 은 원래 "이 머신의 물리 메모리" 를 보고 힙 크기를 정한다.
# 그런데 컨테이너에는 별도의 메모리 제한(cgroup limit)이 걸린다.
# 이걸 JVM 이 모르면 -> 호스트 32GB 기준으로 힙을 잡음 -> 컨테이너 제한 512MB 초과
# -> 리눅스 커널이 프로세스를 강제 종료 (OOMKilled). 실무에서 매우 흔한 사고다.
#
#   -XX:+UseContainerSupport   : 컨테이너 메모리 제한을 인식하라 (최신 JVM 은 기본값이지만 의도를 남긴다)
#   -XX:MaxRAMPercentage=75.0  : 그 제한의 75% 까지만 힙으로 쓴다
#                                나머지 25% 는 JVM 자체(메타스페이스, 스레드 스택 등)와 여유분
ENV JAVA_OPTS="-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport"

# ----------------------------------------------------------------------------
# ENTRYPOINT = 컨테이너가 시작될 때 실행할 명령
# ----------------------------------------------------------------------------
# sh -c 로 감싸는 이유: $JAVA_OPTS 라는 환경변수를 셸이 펼쳐줘야 하기 때문.
#   ["java", "$JAVA_OPTS", ...] 처럼 쓰면 셸을 안 거쳐서 "$JAVA_OPTS" 라는 글자 그대로 전달된다.
#
# exec 를 붙이는 이유 (중요):
#   exec 없이 실행하면 sh 가 PID 1 이 되고 java 는 자식 프로세스가 된다.
#   이러면 docker stop 이 보내는 종료 신호(SIGTERM)를 sh 가 받고 java 에게 전달하지 않아서,
#   앱이 정리 작업(graceful shutdown)을 못 하고 10초 뒤 강제로 죽는다.
#   exec 는 sh 를 java 로 "대체" 해서 java 가 직접 PID 1 이 되게 한다 -> 신호를 바로 받는다.
#
# JarLauncher = 위에서 레이어로 풀어놓은 형태를 실행해주는 Spring Boot 로더 진입점.
ENTRYPOINT ["sh", "-c", "exec java $JAVA_OPTS org.springframework.boot.loader.launch.JarLauncher"]

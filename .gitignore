# ============================================================================
# 저장소 공통 무시 목록
# 각 예제 폴더가 자기 스택에 맞는 .gitignore 를 추가로 가질 수 있다.
# ============================================================================

# macOS 가 폴더마다 자동 생성하는 메타데이터
.DS_Store

# IDE 설정 (사람마다 달라서 커밋하면 서로 충돌만 난다)
.idea/
*.iml
.vscode/

# 비밀정보 — 공개 저장소이므로 특히 주의
.env
*.pem
*.key
